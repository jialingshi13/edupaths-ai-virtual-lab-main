# Supabase — map from your Desktop .env:
#   url    → VITE_SUPABASE_URL
#   Public → VITE_SUPABASE_ANON_KEY
# Do NOT copy private / key (postgres) / jwt into this file.
# Enable Anonymous Sign-Ins: Dashboard → Authentication → Providers → Anonymous
# (only needed when VITE_EDUPATHS_SSO_ENABLED is not true)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Set to true when integrating with EduPaths main app SSO
VITE_EDUPATHS_SSO_ENABLED=false

# Simple username/password login (teacher / student)
VITE_LAB_AUTH_ENABLED=true
